{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/football/:path*", "destination": "/api/football?path=:path*" },
    { "source": "/api/odds/:path*",     "destination": "/api/odds?path=:path*" },
    { "source": "/((?!api/).*)",        "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
